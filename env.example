# Flask
FLASK_DEBUG=false
PORT=5000

# Cache (seconds)
CACHE_DEFAULT_TIMEOUT=30

# CoinGecko
COINGECKO_TIMEOUT=5.0
COINGECKO_RETRIES=2
COINGECKO_BACKOFF_FACTOR=0.3

# Default coins (comma-separated CoinGecko IDs)
DEFAULT_IDS=bitcoin,ethereum,solana,binancecoin,cardano

# Default vs currency
DEFAULT_VS_CURRENCY=usd

# Anthropic API (for AI coin summaries)
ANTHROPIC_API_KEY=sk-ant-your-key-here
